APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/polymarket_holder_edge_bot
POLYMARKET_API_BASE_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_API_BASE_URL=https://gamma-api.polymarket.com
HTTP_TIMEOUT_SECONDS=10.0
HTTP_MAX_RETRIES=3
HTTP_BACKOFF_SECONDS=0.5
WALLET_SCORE_WEIGHT_ROI=0.4
WALLET_SCORE_WEIGHT_RECENT_ROI=0.3
WALLET_SCORE_WEIGHT_SAMPLE=0.15
WALLET_SCORE_WEIGHT_VOLUME=0.15
WALLET_SAMPLE_SHRINKAGE=20.0
WALLET_VOLUME_REFERENCE=100000.0
WALLET_ROI_WINSOR_LOWER=-1.0
WALLET_ROI_WINSOR_UPPER=3.0
ELITE_WALLET_THRESHOLD=0.7
QUALITY_GAP_THRESHOLD=0.1
MAX_ENTRY_SLIPPAGE=0.03
MAX_ACCEPTABLE_SPREAD=0.02
